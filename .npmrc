# Don't auto-install peerDependencies in this package's node_modules.
#
# The chrome ships its UI/state for a host (a Pitchcraft deck) to consume.
# When the deck installs us via `file:` link, npm symlinks us into the
# deck's node_modules. If we have our OWN copies of next-auth, react,
# framer-motion, etc. in our node_modules, runtime ends up with TWO
# instances — and `useSession` from chrome's instance can't see the
# `<SessionProvider>` from the deck's instance. Classic dual-instance
# peer-dep bug; manifested as
#   `[next-auth]: useSession must be wrapped in a <SessionProvider />`
# at runtime even though the host's tree IS wrapped.
#
# Setting auto-install-peers=false makes `npm install` in this directory
# a no-op for runtime peers — the host supplies them. Don't run a fresh
# `npm install` here unless you've cleared this and intend to vendor.

auto-install-peers=false
legacy-peer-deps=true
